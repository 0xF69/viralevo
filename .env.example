# ViralEvo — Environment Variables
# Copy this file to .env and fill in your values.
# Place at: ~/.openclaw/workspace/viralevo/.env

# Required: Tavily API key for indirect platform search (YouTube, TikTok, Twitter, Instagram, Pinterest, LinkedIn)
# Get free key at: https://tavily.com
TAVILY_API_KEY=

# Optional overrides (defaults shown)
# VIRALEVO_DATA_DIR=~/.openclaw/workspace/viralevo
# VIRALEVO_LANGUAGE=en
# VIRALEVO_REPORT_TIME=08:00
